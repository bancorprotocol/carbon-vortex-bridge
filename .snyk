# Snyk (https://snyk.io) policy file, patches or ignores known vulnerabilities.
version: v1.25.1
# ignores vulnerabilities until expiry date; change duration by modifying expiry date
ignore:
  # brace-expansion ReDoS (CVE-2026-13149) is fixed only in 5.0.7+, whose CJS build exports a
  # non-callable default and breaks the pinned minimatch (5.x/9.x) pulled by mocha/eslint/solhint.
  # No patched version exists on any CJS-callable line, so it cannot be upgraded away without
  # breaking the test/lint tooling. Dev-tooling-only glob matching over hardcoded patterns — the
  # ReDoS input is never attacker-controlled.
  SNYK-JS-BRACEEXPANSION-17706650:
    - '*':
        reason: Only fixed in brace-expansion 5.0.7+, whose CJS export breaks the pinned minimatch; dev-only glob matching, patterns not attacker-controlled
        expires: 2027-07-01T00:00:00.000Z
        created: 2026-07-01T00:00:00.000Z
patch: {}
